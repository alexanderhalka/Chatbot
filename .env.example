# Copy to backend/.env (recommended when running via start_chatbot.py / backend/run.py).
# You can also copy to the project root if you run Flask with cwd at the repo root.

# Ollama
OLLAMA_API_URL=http://localhost:11434/api/chat
OLLAMA_MODEL=llama3.2

# Database (default: SQLite file under backend/instance/chatbot.db)
# For Docker Postgres (after: docker compose up -d):
# DATABASE_URL=postgresql+psycopg2://chatbot:chatbot@localhost:5432/chatbot
